{
    "id": "/readlater/",
  "name": "ReadLater Priority",
  "short_name": "ReadLater",
  "description": "Your personal reading list sorted by deadline",
  "start_url": "https://rampreethamkanchi.github.io/readlater/",
  "scope": "https://rampreethamkanchi.github.io/readlater/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#6366f1",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "https://rampreethamkanchi.github.io/readlater/?share=true",
    "method": "GET",
    "params": {
      "title": "title",
      "url": "url",
      "text": "text"
    }
  }
}
